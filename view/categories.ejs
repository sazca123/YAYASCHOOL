<!-- Модальное окно для записи -->
<div id="enrollment-modal" class="modal" style="display: none;">
  <div class="modal-content">
    <span class="modal-close">&times;</span>
    <h2 class="modal-title">Записаться на занятия</h2>
    <form id="enrollment-form" class="enrollment-form">
      <input type="hidden" name="category" id="modal-category">
      <input type="hidden" name="program" id="modal-program">
      
      <div class="form-group unregistered-fields">
        <input type="text" name="fullName" placeholder="ФИО">
        <input type="tel" name="phone" placeholder="Телефон">
        <input type="email" name="unregisteredEmail" placeholder="Email">
        <input type="text" name="childName" placeholder="ФИО ребенка">
        <input type="number" name="childAge" placeholder="Возраст ребенка" min="5" max="18">
      </div>
      
      <button type="submit" class="enrollment-btn">Записаться</button>
    </form>
    <div class="enrollment-message" style="display: none;"></div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const categoryLinks = document.querySelectorAll('.categories a[data-category]');
    const categoryContents = document.querySelectorAll('.category-content');
    
    // Показываем первую категорию и активируем первую ссылку по умолчанию
    if (categoryLinks.length > 0 && categoryContents.length > 0) {
      const firstLink = categoryLinks[0];
      const firstContent = categoryContents[0];
      firstContent.style.display = 'block';
      firstLink.classList.add('active');
    }
    
    categoryLinks.forEach(link => {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        
        // Получаем категорию из data-атрибута
        const category = this.getAttribute('data-category');
        
        // Скрываем все категории
        categoryContents.forEach(content => {
          content.style.display = 'none';
        });
        
        // Показываем выбранную категорию
        const selectedContent = document.querySelector(`.category-content[data-category="${category}"]`);
        if (selectedContent) {
          selectedContent.style.display = 'block';
        }
        
        // Убираем активный класс со всех ссылок
        categoryLinks.forEach(l => l.classList.remove('active'));
        // Добавляем активный класс к текущей ссылке
        this.classList.add('active');
      });
    });
    
    // Модальное окно
    const modal = document.getElementById('enrollment-modal');
    const modalClose = modal.querySelector('.modal-close');
    const enrollmentForm = document.getElementById('enrollment-form');
    const messageDiv = modal.querySelector('.enrollment-message');
    
    // Открытие модального окна при клике на кнопку "Записаться"
    document.querySelectorAll('.enroll-btn').forEach(btn => {
      btn.addEventListener('click', async function() {
        const category = this.getAttribute('data-category');
        const program = this.getAttribute('data-program');
        
        // Проверяем, зарегистрирован ли пользователь
        const loggedInUser = localStorage.getItem('loggedInUser');
        
        if (loggedInUser) {
          // Пользователь зарегистрирован - показываем информацию и сразу записываем
          const user = JSON.parse(loggedInUser);
          await enrollRegisteredUser(user, category, program, this);
        } else {
          // Пользователь не зарегистрирован - показываем форму
          document.getElementById('modal-category').value = category;
          document.getElementById('modal-program').value = program;
          
          modal.style.display = 'block';
          document.body.style.overflow = 'hidden';
        }
      });
    });
    
    async function enrollRegisteredUser(user, category, program, buttonElement) {
    const card = buttonElement.closest('.category-card');
    const programTitle = card.querySelector('h3') ? card.querySelector('h3').textContent : program;

    const infoModal = document.createElement('div');
    infoModal.className = 'modal';
    infoModal.style.display = 'block';
    infoModal.innerHTML = `
        <div class="modal-content" style="max-width: 700px; max-height: 90vh; overflow-y: auto;">
            <span class="modal-close">&times;</span>
            <h2 class="modal-title">Подтверждение записи</h2>
            <div style="padding: 30px;">
                <h3 style="color:#4840C0; margin-bottom: 20px;">${programTitle}</h3>
                
                <p><strong>Ребёнок:</strong> ${user.childName} (${user.childAge} лет)</p>
                <p><strong>Родитель:</strong> ${user.fullName}</p>
                <p><strong>Телефон:</strong> ${user.phone}</p>
                
                <div id="enrollment-info-message" class="enrollment-message" style="display:none; margin:20px 0;"></div>
                
                <button id="confirm-enrollment-btn" class="enrollment-btn">Подтвердить запись на кружок</button>
                <button id="cancel-enrollment-btn" style="width:100%; margin-top:10px; padding:12px; background:#f0f0f0; border:none; border-radius:6px; cursor:pointer;">Отмена</button>
            </div>
        </div>
    `;

    document.body.appendChild(infoModal);
    document.body.style.overflow = 'hidden';

    const messageDiv = infoModal.querySelector('#enrollment-info-message');
    const confirmBtn = infoModal.querySelector('#confirm-enrollment-btn');
    const cancelBtn = infoModal.querySelector('#cancel-enrollment-btn');
    const closeBtn = infoModal.querySelector('.modal-close');

    const closeModal = () => {
        infoModal.remove();
        document.body.style.overflow = 'auto';
    };

    closeBtn.addEventListener('click', closeModal);
    cancelBtn.addEventListener('click', closeModal);

    confirmBtn.addEventListener('click', async () => {
        confirmBtn.disabled = true;
        confirmBtn.textContent = 'Записываем...';
        messageDiv.style.display = 'block';
        messageDiv.textContent = 'Отправка заявки...';
        messageDiv.className = 'enrollment-message';

        try {
            const response = await fetch('/api/enroll', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    category: category,
                    program: programTitle,
                    userType: 'registered',
                    email: user.email,
                    fullName: user.fullName,
                    phone: user.phone,
                    childName: user.childName,
                    childAge: user.childAge
                })
            });

            const result = await response.json();

            if (response.ok) {
                messageDiv.className = 'enrollment-message success';
                messageDiv.textContent = 'Ребёнок успешно записан!';
                confirmBtn.style.display = 'none';
                setTimeout(closeModal, 2000);
            } else {
                messageDiv.className = 'enrollment-message error';
                messageDiv.textContent = result.error || 'Ошибка при записи';
                confirmBtn.disabled = false;
                confirmBtn.textContent = 'Подтвердить запись';
            }
        } catch (err) {
            messageDiv.className = 'enrollment-message error';
            messageDiv.textContent = 'Ошибка соединения с сервером';
            confirmBtn.disabled = false;
            confirmBtn.textContent = 'Подтвердить запись';
        }
    });
}
    
    // Закрытие модального окна
    modalClose.addEventListener('click', function() {
      modal.style.display = 'none';
      document.body.style.overflow = 'auto';
      enrollmentForm.reset();
      messageDiv.style.display = 'none';
    });
    
    // Закрытие при клике вне модального окна
    window.addEventListener('click', function(e) {
      if (e.target === modal) {
        modal.style.display = 'none';
        document.body.style.overflow = 'auto';
        enrollmentForm.reset();
        messageDiv.style.display = 'none';
      }
    });
    
    
    // Обработка отправки формы в модальном окне
    enrollmentForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      const formData = new FormData(this);
      const category = formData.get('category');
      const program = formData.get('program');
      const fullName = formData.get('fullName');
      const phone = formData.get('phone');
      const email = formData.get('unregisteredEmail');
      const childName = formData.get('childName');
      const childAge = formData.get('childAge');
      
      // Проверяем все обязательные поля
      const missingFields = [];
      if (!category) missingFields.push('категория');
      if (!program) missingFields.push('программа');
      if (!fullName) missingFields.push('ФИО родителя');
      if (!phone) missingFields.push('Телефон');
      if (!email) missingFields.push('Email');
      if (!childName) missingFields.push('ФИО ребенка');
      if (!childAge) missingFields.push('Возраст ребенка');
      
      if (missingFields.length > 0) {
        messageDiv.textContent = 'Не заполнены поля: ' + missingFields.join(', ');
        messageDiv.className = 'enrollment-message error';
        messageDiv.style.display = 'block';
        return;
      }
      
      const data = {
        category: category,
        userType: 'unregistered',
        program: program,
        fullName: fullName,
        phone: phone,
        email: email,
        childName: childName,
        childAge: childAge
      };
      
      messageDiv.style.display = 'block';
      messageDiv.textContent = 'Отправка...';
      messageDiv.className = 'enrollment-message';
      
      try {
        const response = await fetch('/api/enroll', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(data)
        });
        
        const result = await response.json();
        
        if (response.ok) {
          messageDiv.textContent = 'Запись успешно отправлена!';
          messageDiv.className = 'enrollment-message success';
          setTimeout(() => {
            modal.style.display = 'none';
            document.body.style.overflow = 'auto';
            enrollmentForm.reset();
            messageDiv.style.display = 'none';
          }, 2000);
        } else {
          messageDiv.textContent = result.error || 'Ошибка при отправке записи';
          messageDiv.className = 'enrollment-message error';
        }
      } catch (error) {
        messageDiv.textContent = 'Ошибка соединения с сервером';
        messageDiv.className = 'enrollment-message error';
      }
    });
  });
</script>

