<!DOCTYPE html>
<html lang="ru">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>
        Все ученики
    </title>

    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="/css/dashboard.css">

</head>

<body class="dashboard-body">

<%- include('../navigation') %>

<div class="dashboard-layout">

    <!-- SIDEBAR -->

    <aside class="dashboard-sidebar">

        <div class="sidebar-profile glass-card">

            <div class="avatar-circle">

                <%= user.fullName
                    ? user.fullName.charAt(0)
                    : 'П'
                %>

            </div>

            <h3>
                <%= user.fullName %>
            </h3>

            <p>
                Преподаватель
            </p>

        </div>

        <div class="sidebar-menu glass-card">

            <a
                href="/teacher/dashboard?user=<%= encodeURIComponent(JSON.stringify(user)) %>"
                class="sidebar-link"
            >
                📋 Панель
            </a>

            <a
                href="/teacher/students?user=<%= encodeURIComponent(JSON.stringify(user)) %>"
                class="sidebar-link active"
            >
                👨‍🎓 Все ученики
            </a>

        </div>

    </aside>

    <!-- MAIN -->

    <main class="dashboard-main">

        <section class="dashboard-section glass-card">

            <div class="section-header">

                <h2>
                    Подтверждённые ученики
                </h2>

            </div>

            <div class="students-modern-grid">

                <% if(students.length === 0){ %>

                    <div class="empty-box">

                        Пока нет подтверждённых учеников

                    </div>

                <% } %>

                <% students.forEach(student => { %>

                    <div class="student-modern-card glass-card">

                        <div class="student-card-top">

                            <div class="student-avatar-modern">

                                <%= student.childName
                                    ? student.childName.charAt(0)
                                    : 'У'
                                %>

                            </div>

                            <div>

                                <h3>
                                    <%= student.childName %>
                                </h3>

                                <p>
                                    <%= student.childAge || '—' %> лет
                                </p>

                            </div>

                        </div>

                        <div class="student-info-list">

                            <div class="student-info-row">

                                <span>Родитель</span>

                                <strong>
                                    <%= student.fullName || '—' %>
                                </strong>

                            </div>

                            <div class="student-info-row">

                                <span>Телефон</span>

                                <strong>
                                    <%= student.phone || '—' %>
                                </strong>

                            </div>

                            <div class="student-info-row">

                                <span>Email</span>

                                <strong>
                                    <%= student.email || '—' %>
                                </strong>

                            </div>

                        </div>

                        <div class="student-card-bottom">

                            <span class="modern-status modern-status-confirmed">

                                Обучается

                            </span>

                        </div>

                    </div>

                <% }) %>

            </div>

        </section>

    </main>

</div>

<%- include('../footer') %>

</body>
</html>