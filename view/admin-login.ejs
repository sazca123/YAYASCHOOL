<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Вход в Админ Панель</title>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body {
            font-family: 'Inter', system-ui, sans-serif;
            background: #f4f4f9;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-container {
            background: white;
            padding: 40px 35px;
            border-radius: 16px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 420px;
        }
        h1 { color: #4840C0; text-align: center; margin-bottom: 8px; }
        p { text-align: center; color: #666; margin-bottom: 30px; }
        input {
            width: 100%;
            padding: 14px;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            font-size: 16px;
            margin-bottom: 20px;
        }
        input:focus {
            outline: none;
            border-color: #4840C0;
        }
        button {
            width: 100%;
            padding: 14px;
            background: #4840C0;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 17px;
            font-weight: 700;
            cursor: pointer;
        }
        button:hover { background: #3930a0; }
        .message {
            padding: 12px;
            margin: 15px 0;
            border-radius: 8px;
            text-align: center;
            font-weight: 500;
            display: none;
        }
        .error { background: #f8d7da; color: #721c24; }
    </style>
</head>
<body>
    <div class="login-container">
        <h1>Админ Панель</h1>
        <p>Детская школа искусств №51</p>

        <div id="message" class="message"></div>

        <form id="admin-login-form">
            <input type="email" id="email" placeholder="Email администратора" required>
            <input type="password" id="password" placeholder="Пароль" required>
            <button type="submit">Войти</button>
        </form>

        <div style="text-align:center; margin-top:20px; font-size:14px; color:#666;">
            Тестовые данные:<br>
            <strong>admin@alexander.ru</strong> / <strong>admin123</strong>
        </div>
    </div>

    <script>
    document.getElementById('admin-login-form').addEventListener('submit', async (e) => {
        e.preventDefault();

        const email = document.getElementById('email').value.trim();
        const password = document.getElementById('password').value.trim();
        const messageDiv = document.getElementById('message');

        messageDiv.style.display = 'block';
        messageDiv.className = 'message';
        messageDiv.textContent = 'Проверка...';

        try {
            console.log('Отправляем:', { email, password }); // для отладки

            const response = await fetch('/api/admin/verify', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, password })
            });

            const data = await response.json();
            console.log('Ответ сервера:', data); // для отладки

            if (response.ok && data.success) {

    localStorage.setItem('adminEmail', email);
    localStorage.setItem('adminPassword', password);
    
    alert('Вход успешный');

    console.log('Сохранили email:', localStorage.getItem('adminEmail'));
    console.log('Сохранили пароль:', localStorage.getItem('adminPassword'));

    window.location.href =
        `/admin?adminEmail=${encodeURIComponent(email)}&adminPassword=${encodeURIComponent(password)}`;
} else {
                messageDiv.className = 'message error';
                messageDiv.textContent = data.error || 'Неверные данные';
            }
        } catch (err) {
            console.error(err);
            messageDiv.className = 'message error';
            messageDiv.textContent = 'Ошибка соединения с сервером';
        }
    });
</script>
</body>
</html>