<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Школа 51</title>
  <link rel="stylesheet" href="/styles.css">
</head>


<body>
    <%- include('navigation') %>
    
    <main>
      <div class="banner">
        <div class="left">
            <h1>ДЕТСКАЯ ШКОЛА ИСКУССТВ 51</h1>
            <span>
                <button id="scroll-to-categories">
    Записаться на занятия
</button>
                <a href="/vk.com">
                    <svg width="55" height="55" viewBox="0 0 55 55" fill="none" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
                        <rect width="55" height="55" fill="url(#pattern0_68_764)"/>
                        <defs>
                        <pattern id="pattern0_68_764" patternContentUnits="objectBoundingBox" width="1" height="1">
                        <use xlink:href="#image0_68_764" transform="translate(0 -0.00724638) scale(0.0144928)"/>
                        </pattern>
                        <image id="image0_68_764" width="69" height="70" preserveAspectRatio="none" xlink:href="data:image/png;base64,"/>
                        </defs>
                    </svg>
                </a>
            </span>
            <img src="/media/Rectangle 29.png" alt="">
        </div>
        <div class="right">
            <div class="banner-images">
                <img src="/media/banner/Rectangle 3.png" alt="">
                <img src="/media/banner/Rectangle 4.png" alt="">
                <img src="/media/banner/Rectangle 5.png" alt="">
                <img src="/media/banner/Rectangle 6.png" alt="">
                <img src="/media/banner/Rectangle 7.png" alt="">
                <img src="/media/banner/Rectangle 8.png" alt="">
                <img src="/media/banner/Rectangle 9.png" alt="">
                <img src="/media/banner/Rectangle 10.png" alt="">
            </div>
        </div>

      </div>
      <div class="label-left">
        <h1>Отделения</h1>
      </div>
      <div class="categories" id="departments">
        <ul>
            <li><a href="/categories/choreography" data-category="choreography">Хореография</a></li>
            <li><a href="/categories/art" data-category="art">Художественное</a></li>
            <li><a href="/categories/music" data-category="music">Музыкальное</a></li>
            <li><a href="/categories/vocal" data-category="vocal">Вокальное</a></li>
        </ul>
      </div>
      <%- include('categories') %>
      <%- include('news') %>
    </main> 
    
    <%- include('footer') %>

    <script>

document
    .getElementById('scroll-to-categories')
    .addEventListener('click', () => {

        document
            .getElementById('departments')
            .scrollIntoView({
                behavior: 'smooth'
            });

    });

</script>

</body>
</html>
